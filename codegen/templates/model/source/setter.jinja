{% if prop.props.type not in ["class", "collection", "string"] %}
    void {{props.name}}::Set{{prop.props.name | PascalCase}}({{prop.props.name | PascalCase}}Type value) {
        if (value != _{{prop.props.name | camelCase}}) {
            auto oldValue = std::move(_{{prop.props.name | camelCase}});
            _{{prop.props.name | camelCase}} = std::move(value);
            _NotifySubscribers({{prop.props.name | CONST_CASE}}_PROP, &oldValue, &value);
        }
    }
{% else %}
    void {{props.name}}::Set{{prop.props.name | PascalCase}}(const {{prop.props.name | PascalCase}}Type & value) {
        if (value != _{{prop.props.name | camelCase}}) {
            auto oldValue = std::move(_{{prop.props.name | camelCase}});
            _{{prop.props.name | camelCase}} = value;
            _NotifySubscribers({{prop.props.name | CONST_CASE}}_PROP, &oldValue, &value);
        }
    }
{% endif %}
